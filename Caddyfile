# ================================================================
# Caddyfile — Configuration locale avec HTTPS (tls internal)
# Caddy génère une CA locale automatiquement.
# Pour la production : retirer "tls internal", Caddy utilisera
# Let's Encrypt automatiquement avec un vrai domaine.
# ================================================================

{
    admin off
}

# --- Portail d'authentification Authelia ---
auth.llm.test {
    tls internal
    reverse_proxy authelia:9091
}

# --- Open WebUI (Interface chat) ---
chat.llm.test {
    tls internal
    forward_auth authelia:9091 {
        uri /api/authz/forward-auth
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    }
    reverse_proxy open-webui:8080
}

# --- Nextcloud (Cloud privé) ---
cloud.llm.test {
    tls internal
    forward_auth authelia:9091 {
        uri /api/authz/forward-auth
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    }
    reverse_proxy nextcloud:80
}

# --- Portainer (Gestion Docker) ---
portainer.llm.test {
    tls internal
    forward_auth authelia:9091 {
        uri /api/authz/forward-auth
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    }
    reverse_proxy portainer:9000
}
